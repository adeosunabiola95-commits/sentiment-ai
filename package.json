{
  "name": "sentiment-ai",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,magenta \"npm run dev --prefix frontend\" \"npm run dev --prefix backend\"",
    "dev:web": "npm run dev --prefix frontend",
    "dev:api": "npm run dev --prefix backend",
    "build": "npm run build --prefix frontend",
    "start": "npm run start --prefix frontend",
    "lint": "npm run lint --prefix frontend",
    "start:api": "npm start --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
